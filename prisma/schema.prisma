generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Utilisateurs de l'outil ────────────────────────────────────────────────

enum Role {
  ADMIN
  VALIDATEUR
  TECHNICIEN
  DEMANDEUR
  LECTEUR
}

model User {
  id           String   @id @default(cuid())
  login        String   @unique // sAMAccountName ou identifiant local
  displayName  String
  email        String?
  role         Role     @default(DEMANDEUR)
  isLocal      Boolean  @default(false)
  passwordHash String?
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())

  // délégation d'absence : les validations dues à cet utilisateur sont aussi
  // proposées au délégué pendant la fenêtre d'absence.
  absent        Boolean   @default(false)
  delegateToId  String?
  delegateFrom  DateTime?
  delegateTo    DateTime?
  delegateTo_   User?     @relation("delegation", fields: [delegateToId], references: [id], onDelete: SetNull)
  delegatesFor  User[]    @relation("delegation")

  requests         Request[]           @relation("requester")
  validations      RequestValidation[]
  tasksDone        ProvisionTask[]     @relation("doneBy")
  tasksResponsable ProvisionTask[]     @relation("taskResponsable")
  auditLogs        AuditLog[]
  equipementsResponsable Equipement[]  @relation("equipementResponsable")
  magicTokens      MagicToken[]
}

// Jeton de connexion sans mot de passe (magic link envoyé par mail), à usage
// unique et à durée limitée.
model MagicToken {
  id        String    @id @default(cuid())
  token     String    @unique
  userId    String
  next      String? // chemin de redirection après connexion
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ── Référentiel agents ─────────────────────────────────────────────────────

enum AgentStatut {
  ACTIF
  PARTI
}

model Agent {
  id            String      @id @default(cuid())
  civilite      String?
  nom           String
  prenom        String
  matricule     String?
  email         String?
  telephone     String?
  statutEmploi  String // Titulaire, Contractuel, Stagiaire, Apprenti, Élu, Prestataire…
  direction     String?
  service       String?
  fonction      String?
  site          String?
  responsable   String?
  dateArrivee   DateTime?
  dateDepart    DateTime?
  dateFinContrat DateTime?
  statut        AgentStatut @default(ACTIF)
  teletravail   String? // ex. « 2 jours / semaine »
  adLogin       String? // rapprochement avec le compte AD (sAMAccountName)
  commentaire   String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  accesses AgentAccess[]
  requests Request[]
}

// ── Applications métiers & accès ───────────────────────────────────────────

// Fonction « système » que peut remplir une application : elle relie certains
// besoins transverses des demandes (messagerie, téléphonie/télétravail) à
// l'application concrète qui les assure, pour générer des tâches rattachées.
enum AppFonction {
  MESSAGERIE // boîte mail (ex. Zimbra, Exchange)
  TELEPHONIE // téléphonie / VPN / télétravail (ex. 3CX)
  COMPTE_AD // compte / annuaire (ex. Active Directory, IAM)
  CONTROLE_ACCES // badge / accès aux locaux
  PARC // parc / matériel (ex. GLPI)
  POSTE // antivirus / MDM / poste de travail
}

model Application {
  id          String       @id @default(cuid())
  nom         String       @unique
  description String?
  referent    String? // référent fonctionnel ou technique
  profils     String? // profils possibles, séparés par des virgules
  fonction    AppFonction? @unique // au plus une application par fonction système
  actif       Boolean      @default(true)
  source      String       @default("local") // local | sentinelle
  externalId  String?      @unique // id de l'Asset côté Sentinelle
  createdAt   DateTime     @default(now())

  accesses AgentAccess[]
  tasks    ProvisionTask[]
  services ServiceApplication[]
}

// ── Services (catalogue) ───────────────────────────────────────────────────
// Un service correspond au service d'affectation de l'agent. On y rattache
// les applications métiers proposées à la demande et, au plus, un circuit de
// validation par type de demande (création / modification / départ).

model Service {
  id          String   @id @default(cuid())
  nom         String   @unique
  description String?
  actif       Boolean  @default(true)
  adGroups    String? // groupes AD rattachés (un par ligne) : proposent le service selon l'appartenance du demandeur
  createdAt   DateTime @default(now())

  workflowCreationId     String?
  workflowModificationId String?
  workflowDepartId       String?
  workflowCreation     Workflow? @relation("ServiceCreation", fields: [workflowCreationId], references: [id], onDelete: SetNull)
  workflowModification Workflow? @relation("ServiceModification", fields: [workflowModificationId], references: [id], onDelete: SetNull)
  workflowDepart       Workflow? @relation("ServiceDepart", fields: [workflowDepartId], references: [id], onDelete: SetNull)

  applications ServiceApplication[]
}

model ServiceApplication {
  serviceId     String
  applicationId String

  service     Service     @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  application Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@id([serviceId, applicationId])
  @@index([applicationId])
}

// ── Équipements (catalogue) ────────────────────────────────────────────────
// Matériel proposé à la création d'un agent, avec un responsable (utilisateur
// Sésame) chargé de sa préparation.

model Equipement {
  id            String   @id @default(cuid())
  nom           String   @unique
  responsableId String?
  actif         Boolean  @default(true)
  createdAt     DateTime @default(now())

  responsable User? @relation("equipementResponsable", fields: [responsableId], references: [id], onDelete: SetNull)

  @@index([responsableId])
}

enum AccessStatut {
  ACTIF
  A_SUPPRIMER
  SUPPRIME
}

model AgentAccess {
  id              String       @id @default(cuid())
  agentId         String
  applicationId   String
  profil          String?
  statut          AccessStatut @default(ACTIF)
  dateAttribution DateTime     @default(now())
  dateSuppression DateTime?
  commentaire     String?

  agent       Agent       @relation(fields: [agentId], references: [id], onDelete: Cascade)
  application Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@index([agentId])
  @@index([applicationId])
}

// ── Demandes & workflow ────────────────────────────────────────────────────

enum RequestType {
  CREATION
  MODIFICATION
  DEPART
}

enum RequestStatut {
  BROUILLON // circuit à confirmer par le demandeur avant lancement
  EN_VALIDATION
  APPROUVEE // validée, en cours de provisionnement
  REFUSEE
  TERMINEE
  ANNULEE
}

model Workflow {
  id           String      @id @default(cuid())
  nom          String // ex. « Circuit DRH », « Circuit services techniques »
  type         RequestType
  actif        Boolean     @default(true)
  isDefault    Boolean     @default(false) // circuit retenu quand aucun critère ne correspond
  matchService String? // s'applique si le service de la demande correspond
  matchAdGroup String? // s'applique si le demandeur appartient à ce groupe AD
  priorite     Int         @default(0) // plus élevé = examiné en premier
  createdAt    DateTime    @default(now())

  steps    WorkflowStep[]
  requests Request[]

  // services qui rattachent ce circuit (au plus un circuit par type et par service)
  servicesCreation     Service[] @relation("ServiceCreation")
  servicesModification Service[] @relation("ServiceModification")
  servicesDepart       Service[] @relation("ServiceDepart")
}

model WorkflowStep {
  id               String @id @default(cuid())
  workflowId       String
  ordre            Int
  nom              String // ex. « Validation chef de service »
  validatorRole    Role? // tout utilisateur ayant ce rôle peut valider
  validatorUserIds String? // ou liste d'ids utilisateurs, séparés par des virgules

  workflow Workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  @@unique([workflowId, ordre])
}

model Request {
  id              String        @id @default(cuid())
  numero          Int           @unique @default(autoincrement())
  type            RequestType
  statut          RequestStatut @default(EN_VALIDATION)
  requesterId     String
  agentId         String? // agent concerné (modification / départ)
  workflowId      String? // circuit modèle d'origine (référence ; les étapes sont figées)
  payload         Json // fiche complète de la demande
  currentStepOrdre Int          @default(1)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  closedAt        DateTime?

  requester   User                @relation("requester", fields: [requesterId], references: [id])
  agent       Agent?              @relation(fields: [agentId], references: [id])
  workflow    Workflow?           @relation(fields: [workflowId], references: [id], onDelete: SetNull)
  steps       RequestStep[]
  validations RequestValidation[]
  tasks       ProvisionTask[]

  @@index([statut])
}

enum StepMode {
  SEQUENTIEL // un seul valideur suffit pour avancer
  PARALLELE // plusieurs valideurs sollicités ; « requis » validations nécessaires
}

// Étapes figées (snapshot) du circuit sur la demande : préserve l'historique si
// le modèle change et permet l'édition du circuit au dépôt (ajout / retrait /
// réordonnancement / remplacement de valideurs).
model RequestStep {
  id               String   @id @default(cuid())
  requestId        String
  ordre            Int
  nom              String
  mode             StepMode @default(SEQUENTIEL)
  requis           Int      @default(1)
  validatorRole    Role?
  validatorUserIds String? // liste d'ids utilisateurs, séparés par des virgules

  request Request @relation(fields: [requestId], references: [id], onDelete: Cascade)

  @@unique([requestId, ordre])
}

enum Decision {
  APPROUVE
  REFUSE
  RENVOYE // renvoi à une étape précédente pour correction
}

model RequestValidation {
  id          String   @id @default(cuid())
  requestId   String
  stepOrdre   Int
  stepNom     String
  decision    Decision
  targetOrdre Int? // en cas de renvoi : étape de destination
  userId      String
  commentaire String?
  createdAt   DateTime @default(now())

  request Request @relation(fields: [requestId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id])
}

enum TaskStatut {
  A_FAIRE
  FAIT
  NON_APPLICABLE
}

model ProvisionTask {
  id            String     @id @default(cuid())
  requestId     String
  label         String
  categorie     String // AD, Messagerie, Application, Matériel, Autre
  applicationId String?
  responsableId String? // utilisateur en charge (ex. responsable d'un équipement)
  statut        TaskStatut @default(A_FAIRE)
  doneById      String?
  doneAt        DateTime?

  request     Request      @relation(fields: [requestId], references: [id], onDelete: Cascade)
  application Application? @relation(fields: [applicationId], references: [id])
  responsable User?        @relation("taskResponsable", fields: [responsableId], references: [id])
  doneBy      User?        @relation("doneBy", fields: [doneById], references: [id])

  @@index([responsableId])
}

// ── Annuaire AD (lecture seule) ────────────────────────────────────────────

model AdAccount {
  id             String    @id @default(cuid())
  samAccountName String    @unique
  displayName    String?
  email          String?
  dn             String
  ou             String?
  enabled        Boolean   @default(true)
  lastLogon      DateTime?
  groups         String? // noms des groupes, séparés par des retours ligne
  manager        String? // DN du responsable hiérarchique (attribut AD « manager »)
  syncedAt       DateTime  @default(now())

  @@index([manager])
}

// ── Paramétrage & audit ────────────────────────────────────────────────────

model Setting {
  key   String @id
  value String // JSON
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  action    String
  cible     String?
  details   String?
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id])

  @@index([createdAt])
}
