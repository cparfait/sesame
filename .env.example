# Base de données PostgreSQL
DATABASE_URL="postgresql://sesame:sesame@localhost:5433/sesame"

# Secret de session (32+ caractères aléatoires)
SESSION_SECRET="changez-moi-chaine-aleatoire-de-32-caracteres-minimum"

# Mot de passe initial du compte local « admin » (créé au premier démarrage
# tant qu'aucun administrateur actif n'existe)
SESAME_ADMIN_PASSWORD="sesame"

# Mettre à 0 si l'application est servie en HTTP simple (sans reverse proxy TLS)
# COOKIE_SECURE=0
